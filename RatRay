        FOVCircle.Visible=true; FOVCircle.Position=UIS:GetMouseLocation(); FOVCircle.Radius=AimbotFOV
        FOVCircle.Color=FOV_Color; FOVCircle.Thickness=FOV_Thickness; FOVCircle.Transparency=FOV_Transparency
    else FOVCircle.Visible=false end

    -- Local Character Logic
    local Char=LocalPlayer.Character; if not Char then return end
    local Root=Char:FindFirstChild("HumanoidRootPart"); local Hum=Char:FindFirstChildOfClass("Humanoid")
    if not Root or not Hum then return end

    -- Third Person
    if ThirdPerson_Enabled and Hum.Health>0 then
        LocalPlayer.CameraMaxZoomDistance=ThirdPerson_Distance; LocalPlayer.CameraMinZoomDistance=ThirdPerson_Distance
        UIS.MouseBehavior=Enum.MouseBehavior.LockCenter
        local lv=Camera.CFrame.LookVector; Root.CFrame=CFrame.new(Root.Position,Root.Position+Vector3.new(lv.X,0,lv.Z))
    elseif not FlyEnabled then LocalPlayer.CameraMaxZoomDistance=25; LocalPlayer.CameraMinZoomDistance=0.5 end

    -- BunnyHop
    if BunnyHopEnabled and Hum.FloorMaterial~=Enum.Material.Air then Hum.Jump=true end

    -- Anti-Aim
    if AntiAim_Enabled and Hum.Health>0 and not (Hum.SeatPart and Hum.SeatPart:IsA("VehicleSeat")) then
        local yaw=math.rad(AntiAim_Yaw); local pitch=math.rad(AntiAim_Pitch)
        if AntiAim_Mode=="Jitter" then yaw+=math.sin(tick()*45)*math.rad(AntiAim_JitterRange)
        elseif AntiAim_Mode=="Randomize" then yaw=math.rad(math.random(-180,180)); pitch=math.rad(math.random(-45,45)) end
        Root.CFrame=CFrame.new(Root.Position)*CFrame.Angles(pitch,yaw,0)
        local core=Char:FindFirstChild("Torso") or Char:FindFirstChild("UpperTorso")
        if core and core:FindFirstChild("Neck") then
            local rh=math.rad(AntiAim_HeadPitch)
            core.Neck.C0=(Hum.RigType==Enum.RigType.R6 and CFrame.new(0,1,0) or CFrame.new(0,0.8,0))*CFrame.Angles(rh,0,0)
        end
    end

    -- AIMBOT + TARGET ESP SAVE
    CurrentAimTarget = nil
    if AimbotEnabled then
        local pressed=IsMouseBind and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) or UIS:IsKeyDown(AimbotKey)
        if pressed then
            local T=GetClosestPlayer()
            CurrentAimTarget = T
            if T and T.Character and T.Character:FindFirstChild("Head") then
                local tr=T.Character:FindFirstChild("HumanoidRootPart")
                local vel=tr and tr.AssemblyLinearVelocity or Vector3.zero
                local pred=T.Character.Head.Position+(vel*AimbotPredict)
                Camera.CFrame=Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position,pred),AimbotSpeed)
            end
        end
    end

    -- TARGET ESP RENDERING
    if TargetESP_Enabled and CurrentAimTarget and CurrentAimTarget.Character then
        local tRoot = CurrentAimTarget.Character:FindFirstChild("HumanoidRootPart")
        if tRoot then
            local pos, onScreen = Camera:WorldToViewportPoint(tRoot.Position)
            if onScreen then
                local cx, cy = pos.X, pos.Y
                
                if TargetESP_Mode == "Crosshair" then
                    if #TargetESPCache.Lines < 4 then
                        for i = 1, 4 do table.insert(TargetESPCache.Lines, Drawing.new("Line")) end
                        TargetESPCache.Center = Drawing.new("Circle")
                        TargetESPCache.Center.Filled = true
                    end
                    local size = 15
                    for _, l in pairs(TargetESPCache.Lines) do l.Thickness = 2; l.Color = Color3.fromRGB(255, 255, 0); l.Visible = true end
                    TargetESPCache.Lines[1].From = Vector2.new(cx, cy - size); TargetESPCache.Lines[1].To = Vector2.new(cx, cy - size/3)
                    TargetESPCache.Lines[2].From = Vector2.new(cx, cy + size); TargetESPCache.Lines[2].To = Vector2.new(cx, cy + size/3)
                    TargetESPCache.Lines[3].From = Vector2.new(cx - size, cy); TargetESPCache.Lines[3].To = Vector2.new(cx - size/3, cy)
                    TargetESPCache.Lines[4].From = Vector2.new(cx + size, cy); TargetESPCache.Lines[4].To = Vector2.new(cx + size/3, cy)
                    TargetESPCache.Center.Position = Vector2.new(cx, cy); TargetESPCache.Center.Radius = 2; TargetESPCache.Center.Color = Color3.fromRGB(255, 255, 0); TargetESPCache.Center.Visible = true
                    
                elseif TargetESP_Mode == "Box" then
                    if #TargetESPCache.Lines < 4 then
                        for i = 1, 4 do table.insert(TargetESPCache.Lines, Drawing.new("Line")) end
                    end
                    local topPos, _ = Camera:WorldToViewportPoint(tRoot.Position + Vector3.new(0, 3, 0))
                    local botPos, _ = Camera:WorldToViewportPoint(tRoot.Position - Vector3.new(0, 3.5, 0))
                    local h = botPos.Y - topPos.Y; local w = h / 2
                    local x1, y1 = topPos.X - w/2, topPos.Y; local x2, y2 = topPos.X + w/2, botPos.Y
                    for _, l in pairs(TargetESPCache.Lines) do l.Thickness = 2; l.Color = Color3.fromRGB(255, 0, 0); l.Visible = true end
                    TargetESPCache.Lines[1].From = Vector2.new(x1, y1); TargetESPCache.Lines[1].To = Vector2.new(x2, y1)
                    TargetESPCache.Lines[2].From = Vector2.new(x1, y2); TargetESPCache.Lines[2].To = Vector2.new(x2, y2)
                    TargetESPCache.Lines[3].From = Vector2.new(x1, y1); TargetESPCache.Lines[3].To = Vector2.new(x1, y2)
                    TargetESPCache.Lines[4].From = Vector2.new(x2, y1); TargetESPCache.Lines[4].To = Vector2.new(x2, y2)
                    if TargetESPCache.Center then TargetESPCache.Center.Visible = false end
                    
                elseif TargetESP_Mode == "Line" then
                    if #TargetESPCache.Lines < 1 then table.insert(TargetESPCache.Lines, Drawing.new("Line")) end
                    TargetESPCache.Lines[1].From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    TargetESPCache.Lines[1].To = Vector2.new(cx, cy)
                    TargetESPCache.Lines[1].Color = Color3.fromRGB(0, 255, 255)
                    TargetESPCache.Lines[1].Thickness = 1
                    TargetESPCache.Lines[1].Visible = true
                    for i = 2, 4 do if TargetESPCache.Lines[i] then TargetESPCache.Lines[i].Visible = false end end
                    if TargetESPCache.Center then TargetESPCache.Center.Visible = false end
                end
            else
                for _, l in pairs(TargetESPCache.Lines) do l.Visible = false end
                if TargetESPCache.Center then TargetESPCache.Center.Visible = false end
            end
        end
    else
        for _, l in pairs(TargetESPCache.Lines) do l.Visible = false end
        if TargetESPCache.Center then TargetESPCache.Center.Visible = false end
    end

    -- FAKE LAG (Position Choking)
    if FakeLagEnabled and not FlyEnabled then
        FakeLagCounter = FakeLagCounter + 1
        if FakeLagCounter % math.max(1, math.floor(20 - FakeLagIntensity)) == 0 then
            if Root and Hum.Health > 0 then
                if not FakeLagLastPos then FakeLagLastPos = Root.Position end
                pcall(function()
                    Root.CFrame = CFrame.new(FakeLagLastPos) * CFrame.Angles(0, Root.Orientation.Y, 0)
                    Root.AssemblyLinearVelocity = Vector3.new(0, Root.AssemblyLinearVelocity.Y, 0)
                end)
            end
        else
            FakeLagLastPos = Root.Position
        end
    else
        FakeLagLastPos = nil
        FakeLagCounter = 0
    end

    -- Noclip
    if NoclipMode=="Default" then for _,p in pairs(Char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
    elseif NoclipMode=="CounterMine" and Hum.MoveDirection.Magnitude>0 then
        local rp=RaycastParams.new(); rp.FilterDescendantsInstances={Char}; rp.FilterType=Enum.RaycastFilterType.Exclude
        local res=workspace:Raycast(Root.Position,Hum.MoveDirection*4,rp)
        if res and res.Instance then Root.CFrame=Root.CFrame:Lerp(CFrame.new(Root.Position+(Hum.MoveDirection*1.8)),0.4) end
    end

    -- AIR-STRAFE (MINECRAFT STYLE)
    if StrafeEnabled and not FlyEnabled then
        local moveVec = Vector3.new(0, 0, 0)
        if UIS:IsKeyDown(Enum.KeyCode.W) then moveVec += Camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then moveVec -= Camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then moveVec -= Camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then moveVec += Camera.CFrame.RightVector end
        
        moveVec = Vector3.new(moveVec.X, 0, moveVec.Z)
        
        if moveVec.Magnitude > 0 then
            moveVec = moveVec.Unit
            
            if StrafeMode == "Default" then
                local sideDir = Vector3.new(-moveVec.Z, 0, moveVec.X).Unit
                local strafeForce = math.sin(tick() * 18) * StrafeSpeed
                Root.AssemblyLinearVelocity = Vector3.new(
                    Root.AssemblyLinearVelocity.X + (sideDir.X * strafeForce),
                    Root.AssemblyLinearVelocity.Y,
                    Root.AssemblyLinearVelocity.Z + (sideDir.Z * strafeForce)
                )
            elseif StrafeMode == "CounterMine" then
                local currentY = Root.AssemblyLinearVelocity.Y
                Root.AssemblyLinearVelocity = Vector3.new(
                    moveVec.X * StrafeSpeed,
                    currentY,
                    moveVec.Z * StrafeSpeed
                )
            end
        end
    end

    -- Fly
    if FlyEnabled then
        local fv=Vector3.zero
        if UIS:IsKeyDown(Enum.KeyCode.W) then fv+=Camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then fv-=Camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then fv-=Camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then fv+=Camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then fv+=Vector3.new(0,1,0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then fv-=Vector3.new(0,1,0) end
        if FlyBypassMode=="Default" then
            Hum:ChangeState(Enum.HumanoidStateType.Freefall)
            Root.AssemblyLinearVelocity=fv.Magnitude>0 and fv.Unit*FlySpeed or Vector3.new(0,0.1,0)
        elseif FlyBypassMode=="CounterMine" then
            Hum:ChangeState(Enum.HumanoidStateType.Climbing)
            if fv.Magnitude>0 then Root.CFrame+=fv.Unit*(FlySpeed/10) end
            Root.AssemblyLinearVelocity=Vector3.zero
        end
    end

    -- Vehicle + Car Fly
    if Hum.SeatPart and Hum.SeatPart:IsA("VehicleSeat") then
        local seat=Hum.SeatPart; seat.MaxSpeed=CarMaxSpeedLimit
        
        if CarFlyEnabled then
            local flyVel = Vector3.new(0,0,0)
            if UIS:IsKeyDown(Enum.KeyCode.W) then flyVel += seat.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S) then flyVel -= seat.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then flyVel -= seat.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D) then flyVel += seat.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then flyVel += Vector3.new(0,1,0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then flyVel -= Vector3.new(0,1,0) end
            seat.AssemblyLinearVelocity = flyVel.Magnitude > 0 and flyVel.Unit * CarFlySpeed or Vector3.new(0,0,0)
            seat.AssemblyAngularVelocity = Vector3.new(0,0,0)
            return
        end
        
        if FastStopEnabled and UIS:IsKeyDown(FastStopKey) then
            seat.AssemblyLinearVelocity=Vector3.zero; seat.AssemblyAngularVelocity=Vector3.zero; return
        end
        if seat.Steer~=0 then seat.AssemblyAngularVelocity=Vector3.new(0,-seat.Steer*(CarSteerSensitivity*2.5),0) end
        if seat.Throttle~=0 then
            local dir=seat.CFrame.LookVector; if seat.Throttle<0 then dir=-dir end
            local cs=math.max(seat.AssemblyLinearVelocity.Magnitude,10)
            local ts=math.min(cs*CarSpeedMultiplier,CarMaxSpeedLimit)
            local ss=cs+(ts-cs)*CarAccelerationSmooth
            seat.AssemblyLinearVelocity=Vector3.new(dir.X*ss,seat.AssemblyLinearVelocity.Y*0.5,dir.Z*ss)
        end
    end

    -- Targeting Ticks
    SmartFlingTick()
    OrbitTick()
end)

