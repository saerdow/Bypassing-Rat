local function UpdateCasinoUI()
    if BalanceLabel then BalanceLabel.Text = string.format("Баланс: %d 💰", CasinoBalance) end
    if BetLabel then BetLabel.Text = string.format("Ставка: %d", CurrentBet) end
end

local function AdjustBet(amount)
    if IsSpinning then return end
    local newBet = CurrentBet + amount
    if newBet < MinBet then newBet = MinBet end
    if newBet > MaxBet then newBet = MaxBet end
    if newBet > CasinoBalance then newBet = CasinoBalance end
    CurrentBet = newBet
    UpdateCasinoUI()
end

local function SpinSlots()
    if IsSpinning then return end
    
    if CasinoBalance < BankFloor then
        CasinoBalance = BankFloor
        UpdateCasinoUI()
        if StatusLabel then StatusLabel.Text = "🏦 Банк восстановлен до 1000!"; StatusLabel.TextColor3 = Color3.fromRGB(0,255,100) end
        return
    end
    
    if CasinoBalance < CurrentBet then
        if StatusLabel then StatusLabel.Text = "❌ Недостаточно монет!"; StatusLabel.TextColor3 = Color3.fromRGB(255,80,80) end
        return
    end
    
    IsSpinning = true
    CasinoBalance = CasinoBalance - CurrentBet
    UpdateCasinoUI()
    if StatusLabel then StatusLabel.Text = "🎰 Крутим..."; StatusLabel.TextColor3 = Color3.fromRGB(255,255,255) end
    
    local results = {
        SlotSymbols[math.random(1, #SlotSymbols)],
        SlotSymbols[math.random(1, #SlotSymbols)],
        SlotSymbols[math.random(1, #SlotSymbols)]
    }
    
    for i = 1, 3 do
        task.spawn(function()
            local reel = ReelLabels[i]
            if not reel then return end
            local spinDuration = 0.5 + (i * 0.5)
            local startTime = tick()
            while tick() - startTime < spinDuration do
                reel.Text = SlotSymbols[math.random(1, #SlotSymbols)]
                task.wait(0.05)
            end
            reel.Text = results[i]
            reel.TextColor3 = Color3.fromRGB(255, 255, 255)
        end)
    end
    
    task.delay(2.0, function()
        IsSpinning = false
        if results[1] == results[2] and results[2] == results[3] then
            local multiplier = 5
            local symbol = results[1]
            if symbol == "7️⃣" then multiplier = 50
            elseif symbol == "💎" then multiplier = 20
            elseif symbol == "🔔" then multiplier = 10
            elseif symbol == "🍇" then multiplier = 8
            elseif symbol == "🍋" then multiplier = 6
            end
            
            local winAmount = CurrentBet * multiplier
            CasinoBalance = CasinoBalance + winAmount
            
            if StatusLabel then
                StatusLabel.Text = string.format("🎉 ВЫИГРЫШ +%d! (%s x%d)", winAmount, symbol, multiplier)
                StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
            end
            for _, lbl in pairs(ReelLabels) do lbl.TextColor3 = Color3.fromRGB(255, 215, 0) end
        else
            if StatusLabel then
                StatusLabel.Text = "😔 Не повезло..."
                StatusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
            end
        end
        UpdateCasinoUI()
    end)
end

