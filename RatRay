-- AUTOSHOT / KILL AURA (FIXED: 3-TICK SYNC)
-- ==========================================
RunService.Heartbeat:Connect(function()
    if not AutoShotEnabled then 
        AutoShotState = "IDLE"
        AutoShotTargetPart = nil
        AutoShotOriginalCF = nil
        return 
    end
    
    local now = tick()
    local delay = 1 / AutoShotCPS
    
    if AutoShotState == "IDLE" then
        if now - lastAutoShot < delay then return end
        
        local target = GetClosestTarget360()
        if target and target.Character then
            AutoShotTargetPart = AutoShotHitbox == "Head" 
                and target.Character:FindFirstChild("Head") 
                or target.Character:FindFirstChild("HumanoidRootPart")
            
            if AutoShotTargetPart then
                AutoShotState = "AIMING"
                AutoShotOriginalCF = Camera.CFrame
                -- ТИК 1: Только поворачиваем камеру на цель
                pcall(function()
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, AutoShotTargetPart.Position)
                end)
            end
        end
        
    elseif AutoShotState == "AIMING" then
        -- ТИК 2: Камера уже повёрнута с прошлого Heartbeat
        -- Стреляем — сервер видит правильный вектор направления
        pcall(function()
            mouse1click()
        end)
        lastAutoShot = tick()
        AutoShotState = "RETURN"
        
    elseif AutoShotState == "RETURN" then
        -- ТИК 3: Возвращаем камеру обратно (визуально незаметно между кадрами)
        pcall(function()
            if AutoShotOriginalCF then
                Camera.CFrame = AutoShotOriginalCF
            end
        end)
        AutoShotState = "IDLE"
        AutoShotTargetPart = nil
        AutoShotOriginalCF = nil
    end
end)

