local function SmartFlingTick()
    if not FlingActive or not SelectedTarget or not SelectedTarget.Character then return end
    local myRoot=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local tRoot=SelectedTarget.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot or not tRoot then return end
    pcall(function()
        for _,p in pairs(LocalPlayer.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
        local offset=Vector3.new(math.random(-1,1),math.random(-1,1),math.random(-1,1))*0.5
        myRoot.CFrame=tRoot.CFrame*CFrame.new(offset)
        task.spawn(function()
            task.wait()
            if myRoot and tRoot then
                local slamDir=(myRoot.Position-tRoot.Position).Unit
                if slamDir.Magnitude<0.1 then slamDir=Vector3.new(1,1,0) end
                myRoot.AssemblyLinearVelocity=slamDir*FlingPower*3
                myRoot.CFrame=tRoot.CFrame+(slamDir*3)
            end
        end)
    end)
end

local function OrbitTick()
    if not OrbitActive or not SelectedTarget or not SelectedTarget.Character then return end
    local tRoot=SelectedTarget.Character:FindFirstChild("HumanoidRootPart")
    local myRoot=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not tRoot or not myRoot then return end
    pcall(function()
        local t=tick()*OrbitSpeed
        local targetPos=myRoot.Position+Vector3.new(math.sin(t)*OrbitRadius,2,math.cos(t)*OrbitRadius)
        tRoot.CFrame=CFrame.new(targetPos)
        local dir=(targetPos-tRoot.Position).Unit
        tRoot.AssemblyLinearVelocity=dir*(OrbitSpeed*3)
    end)
end

