    ActiveLabels["Fly"].Visible = FlyEnabled

    ActiveLabels["Teleport"].Text = "  [" .. TeleportKey.Name .. "] Teleport: " .. (TeleportMode ~= "None" and "READY" or "DISABLED")
    ActiveLabels["Teleport"].TextColor3 = (TeleportMode ~= "None") and Color3.fromRGB(80, 150, 80) or Color3.fromRGB(120, 120, 140)
    ActiveLabels["Teleport"].Visible = (TeleportMode ~= "None")

    ActiveLabels["FastStop"].Text = "  [" .. FastStopKey.Name .. "] FastStop: " .. (FastStopEnabled and "ACTIVE" or "DISABLED")
    ActiveLabels["FastStop"].TextColor3 = FastStopEnabled and Color3.fromRGB(80, 150, 80) or Color3.fromRGB(120, 120, 140)
    ActiveLabels["FastStop"].Visible = FastStopEnabled

    UpdateWidgetLayout()

    -- Рендеринг Трейсеров, 2D Боксов и Здоровья
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local root = p.Character.HumanoidRootPart
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            local Pos, OnScreen = Camera:WorldToScreenPoint(root.Position)
            local passesTeamCheck = not TeamCheckEnabled or (p.Team ~= LocalPlayer.Team)
            
            -- Трейсеры
            if OnScreen and ESP_Tracers_Enabled and passesTeamCheck and ESP_Enabled then
                if not TracerLines[p.Name] then TracerLines[p.Name] = Drawing.new("Line") end
                local line = TracerLines[p.Name]
                line.Visible = true
                line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                line.To = Vector2.new(Pos.X, Pos.Y)
                line.Color = ESP_Tracers_Color
                line.Thickness = ESP_Tracers_Thickness
                line.Transparency = ESP_Tracers_Transparency
            else
                if TracerLines[p.Name] then TracerLines[p.Name].Visible = false end
            end

            -- 2D Boxes & HealthBar (Drawing)
            if ESP_Cache[p.Name] then
                local esp = ESP_Cache[p.Name]
                if ESP_Boxes_Enabled and OnScreen and passesTeamCheck and hum and hum.Health > 0 then
                    local topPos, topOn = Camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0))
                    local botPos, botOn = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.5, 0))
                    
                    if topOn and botOn then
                        local height = botPos.Y - topPos.Y
                        local width = height / 2
                        local x1, y1 = topPos.X - width / 2, topPos.Y
                        local x2, y2 = topPos.X + width / 2, botPos.Y
                        
                        -- Рисуем линии рамки
                        esp.Lines.Top.From = Vector2.new(x1, y1); esp.Lines.Top.To = Vector2.new(x2, y1)
                        esp.Lines.Bottom.From = Vector2.new(x1, y2); esp.Lines.Bottom.To = Vector2.new(x2, y2)
                        esp.Lines.Left.From = Vector2.new(x1, y1); esp.Lines.Left.To = Vector2.new(x1, y2)
                        esp.Lines.Right.From = Vector2.new(x2, y1); esp.Lines.Right.To = Vector2.new(x2, y2)
                        
                        for _, line in pairs(esp.Lines) do
                            line.Color = ESP_BoxColor
                            line.Visible = true
                        end
                        
                        -- Хелсбар
                        if ESP_HealthBar_Enabled then
                            local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                            local clr = Color3.fromRGB(255, 0, 0):Lerp(Color3.fromRGB(0, 255, 0), pct)
                            local barX = x1 - 5
                            esp.Health.From = Vector2.new(barX, y2)
                            esp.Health.To = Vector2.new(barX, y2 - (height * pct))
                            esp.Health.Color = clr
                            esp.Health.Visible = true
                        else
                            esp.Health.Visible = false
                        end
                    else
                        for _, line in pairs(esp.Lines) do line.Visible = false end
                        esp.Health.Visible = false
                    end
                else
                    for _, line in pairs(esp.Lines) do line.Visible = false end
                    esp.Health.Visible = false
                end
            end
        else
            if TracerLines[p.Name] then TracerLines[p.Name].Visible = false end
            if ESP_Cache[p.Name] then
                for _, line in pairs(ESP_Cache[p.Name].Lines) do line.Visible = false end
                ESP_Cache[p.Name].Health.Visible = false
            end
        end
    end

    -- Рендеринг FOV круга
    if FOV_Visible then
        FOVCircle.Visible = true
        FOVCircle.Position = Vector2.new(UIS:GetMouseLocation().X, UIS:GetMouseLocation().Y)
        FOVCircle.Radius = AimbotFOV
        FOVCircle.Color = FOV_Color
        FOVCircle.Thickness = FOV_Thickness
        FOVCircle.Transparency = FOV_Transparency
    else
        FOVCircle.Visible = false
    end

    local Character = LocalPlayer.Character
    if not Character then return end
    local Root = Character:FindFirstChild("HumanoidRootPart")
    local Humanoid = Character:FindFirstChildOfClass("Humanoid")
    if not Root or not Humanoid then return end
    
    -- ЛОГИКА ТРЕТЬЕГО ЛИЦА С ПОВОРОТОМ ЗА КАМЕРОЙ
    if ThirdPerson_Enabled and Humanoid.Health > 0 then
        LocalPlayer.CameraMaxZoomDistance = ThirdPerson_Distance
        LocalPlayer.CameraMinZoomDistance = ThirdPerson_Distance
        UIS.MouseBehavior = Enum.MouseBehavior.LockCenter
        
        local lookVector = Camera.CFrame.LookVector
        Root.CFrame = CFrame.new(Root.Position, Root.Position + Vector3.new(lookVector.X, 0, lookVector.Z))
    else
        -- Возвращаем лимиты, если выключено
        if not FlyEnabled then
            LocalPlayer.CameraMaxZoomDistance = 25
            LocalPlayer.CameraMinZoomDistance = 0.5
        end
    end

    -- ЛОГИКА BUNNYHOP
    if BunnyHopEnabled and Humanoid.FloorMaterial ~= Enum.Material.Air then 
        Humanoid.Jump = true 
    end

    -- ЛОГИКА ANTI-AIM + НАКЛОН ГОЛОВЫ
    if AntiAim_Enabled and Humanoid.Health > 0 then
        if not (Humanoid.SeatPart and Humanoid.SeatPart:IsA("VehicleSeat")) then
            local currentYaw = math.rad(AntiAim_Yaw)
            local currentPitch = math.rad(AntiAim_Pitch)
            
            if AntiAim_Mode == "Jitter" then
                local modifier = math.sin(tick() * 45) * math.rad(AntiAim_JitterRange)
                currentYaw = currentYaw + modifier
            elseif AntiAim_Mode == "Randomize" then
                currentYaw = math.rad(math.random(-180, 180))
                currentPitch = math.rad(math.random(-45, 45))
            end
            
            Root.CFrame = CFrame.new(Root.Position) * CFrame.Angles(currentPitch, currentYaw, 0)
        end
        
        -- Модификация шейного сустава (Голова)
        local core = Character:FindFirstChild("Torso") or Character:FindFirstChild("UpperTorso")
        if core and core:FindFirstChild("Neck") then
            local radHead = math.rad(AntiAim_HeadPitch)
            if Humanoid.RigType == Enum.RigType.R6 then
                core.Neck.C0 = CFrame.new(0, 1, 0) * CFrame.Angles(radHead, 0, 0)
            else
                core.Neck.C0 = CFrame.new(0, 0.8, 0) * CFrame.Angles(radHead, 0, 0)
            end
        end
    end

    -- ЛОГИКА АИМБОТА
    if AimbotEnabled then
        local isPressed = false
        if IsMouseBind then
            isPressed = UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
        else
            isPressed = UIS:IsKeyDown(AimbotKey)
        end

        if isPressed then
            local Target = GetClosestPlayer()
            if Target and Target.Character and Target.Character:FindFirstChild("Head") then
                local targetRoot = Target.Character:FindFirstChild("HumanoidRootPart")
                local velocity = targetRoot and targetRoot.Velocity or Vector3.new(0,0,0)
                local Prediction = Target.Character.Head.Position + (velocity * AimbotPredict)
                
                Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, Prediction), AimbotSpeed)
            end
        end
    end
    
    if NoclipMode == "Default" then
        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    elseif NoclipMode == "CounterMine" then
        if Humanoid.MoveDirection.Magnitude > 0 then
            local raycastParams = RaycastParams.new()
            raycastParams.FilterDescendantsInstances = {Character}
            raycastParams.FilterType = Enum.RaycastFilterType.Exclude
            
            local raycastResult = workspace:Raycast(Root.Position, Humanoid.MoveDirection * 4, raycastParams)
            if raycastResult and raycastResult.Instance then
                local pushTarget = Root.Position + (Humanoid.MoveDirection * 1.8)
                Root.CFrame = Root.CFrame:Lerp(CFrame.new(pushTarget), 0.4)
            end
        end
    end
    
    -- ЛОГИКА СТРЕЙФОВ (STRAFE)
    if StrafeEnabled and Humanoid.MoveDirection.Magnitude > 0 then
        local sideVector = Vector3.new(-Humanoid.MoveDirection.Z, 0, Humanoid.MoveDirection.X).Unit
        local strafeModifier = math.sin(tick() * 18) * StrafeSpeed
        
        if StrafeMode == "Default" then
            Root.AssemblyLinearVelocity = Root.AssemblyLinearVelocity + (sideVector * strafeModifier)
        elseif StrafeMode == "CounterMine" then
            local offsetPos = Root.Position + (sideVector * (strafeModifier / 15))
            Root.CFrame = Root.CFrame:Lerp(CFrame.new(offsetPos, offsetPos + Root.CFrame.LookVector), 0.3)
            Root.AssemblyLinearVelocity = Vector3.new(Root.AssemblyLinearVelocity.X, 0, Root.AssemblyLinearVelocity.Z)
        end
    end
    
    -- ЛОГИКА ПОЛЕТА (FLY)
    if FlyEnabled then
        local flyVel = Vector3.new(0, 0, 0)
        if UIS:IsKeyDown(Enum.KeyCode.W) then flyVel = flyVel + Camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then flyVel = flyVel - Camera.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then flyVel = flyVel - Camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then flyVel = flyVel + Camera.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space) then flyVel = flyVel + Vector3.new(0, 1, 0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then flyVel = flyVel - Vector3.new(0, 1, 0) end
        
        if FlyBypassMode == "Default" then
            Humanoid:ChangeState(Enum.HumanoidStateType.Freefall)
            if flyVel.Magnitude > 0 then
                Root.AssemblyLinearVelocity = flyVel.Unit * FlySpeed
            else
                Root.AssemblyLinearVelocity = Vector3.new(0, 0.1, 0)
            end
        elseif FlyBypassMode == "CounterMine" then
            Humanoid:ChangeState(Enum.HumanoidStateType.Climbing)
            if flyVel.Magnitude > 0 then
                Root.CFrame = Root.CFrame + (flyVel.Unit * (FlySpeed / 10))
            end
            Root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        end
    end

    if Humanoid.SeatPart and Humanoid.SeatPart:IsA("VehicleSeat") then
        local seat = Humanoid.SeatPart
        seat.MaxSpeed = CarMaxSpeedLimit
        
        if FastStopEnabled and UIS:IsKeyDown(FastStopKey) then
            seat.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            seat.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            return
        end
        
        if seat.Steer ~= 0 then
            local turnDirection = -seat.Steer
            seat.AssemblyAngularVelocity = Vector3.new(0, turnDirection * (CarSteerSensitivity * 2.5), 0)
        end
        
        if seat.Throttle ~= 0 then
            local direction = seat.CFrame.LookVector
            if seat.Throttle < 0 then direction = -direction end
            
            local currentSpeed = math.max(seat.AssemblyLinearVelocity.Magnitude, 10)
            local targetSpeed = currentSpeed * CarSpeedMultiplier
            if targetSpeed > CarMaxSpeedLimit then targetSpeed = CarMaxSpeedLimit end
            
            local smoothSpeed = math.lerp(currentSpeed, targetSpeed, CarAccelerationSmooth)
            seat.AssemblyLinearVelocity = Vector3.new(direction.X * smoothSpeed, seat.AssemblyLinearVelocity.Y * 0.5, direction.Z * smoothSpeed)
        end
    end
end)

