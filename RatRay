RunService.RenderStepped:Connect(function()
    -- Обновление текста и видимости элементов виджета
    ActiveLabels["Aimbot"].Text = "  " .. (IsMouseBind and "[Mouse2]" or "[" .. AimbotKey.Name .. "]") .. " Aimbot: " .. (AimbotEnabled and "ACTIVE" or "DISABLED")
