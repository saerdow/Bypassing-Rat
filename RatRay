if game.CoreGui:FindFirstChild("BypassBitchHub") then game.CoreGui.BypassBitchHub:Destroy() end

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local VIM = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()
local Camera = workspace.CurrentCamera

-- Настройки
local Settings = { AimbotEnabled = false, TriggerBot = false, ESP_Enabled = false, ChamsEnabled = true, Wings = false, JumpCircle = false }
local AimbotFOV, AimbotSpeed, AimbotPredict = 200, 0.1, 0.1
local WingsPart, JumpCircle_Color = nil, Color3.fromRGB(255, 255, 255)

-- [Вспомогательные функции]
local function mouse1press() VIM:SendMouseButtonEvent(0,0,0,true,nil,0) end
local function mouse1release() VIM:SendMouseButtonEvent(0,0,0,false,nil,0) end

local function CreateJumpCircle(pos)
    local p = Instance.new("Part", workspace)
    p.Shape = Enum.PartType.Cylinder; p.Size = Vector3.new(0.1, 1, 1); p.Position = pos - Vector3.new(0, 2.5, 0)
    p.Anchored = true; p.CanCollide = false; p.Material = Enum.Material.Neon; p.Color = JumpCircle_Color
    TweenService:Create(p, TweenInfo.new(0.5), {Size = Vector3.new(0.1, 10, 10), Transparency = 1}):Play()
    game:GetService("Debris"):AddItem(p, 0.6)
end

-- [Интерфейс]
local ScreenGui = Instance.new("ScreenGui", game.CoreGui); ScreenGui.Name = "BypassBitchHub"
local MainFrame = Instance.new("Frame", ScreenGui); MainFrame.Size = UDim2.new(0, 500, 0, 520); MainFrame.Position = UDim2.new(0.3, 0, 0.2, 0); MainFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 45); MainFrame.Active = true; MainFrame.Draggable = true
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 12)

local Content = Instance.new("Frame", MainFrame); Content.Size = UDim2.new(1, -150, 1, -70); Content.Position = UDim2.new(0, 140, 0, 50); Content.BackgroundTransparency = 1

local function CreatePage(name) local p = Instance.new("ScrollingFrame", Content); p.Size = UDim2.new(1,0,1,0); p.BackgroundTransparency = 1; p.Visible = false; Instance.new("UIListLayout", p).Padding = UDim.new(0, 8); return p end
local CombatPage, ESPPage, VisualsPage = CreatePage("Combat"), CreatePage("ESP"), CreatePage("Visuals")
CombatPage.Visible = true

local function AddToggle(p, t, cb) local b = Instance.new("TextButton", p); b.Size = UDim2.new(1,0,0,35); b.BackgroundColor3 = Color3.fromRGB(50,50,60); b.Text = "  "..t; b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.Gotham; Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6); b.MouseButton1Click:Connect(function() b.BackgroundColor3 = (b.BackgroundColor3 == Color3.fromRGB(50,50,60)) and Color3.fromRGB(80,150,80) or Color3.fromRGB(50,50,60); cb(b.BackgroundColor3 == Color3.fromRGB(80,150,80)) end) end

-- [Заполнение меню]
AddToggle(CombatPage, "Rage Auto-Lock", function(s) Settings.AimbotEnabled = s end)
AddToggle(CombatPage, "Rage TriggerBot", function(s) Settings.TriggerBot = s end)
AddToggle(ESPPage, "Team Chams", function(s) Settings.ChamsEnabled = s end)
AddToggle(VisualsPage, "Wings", function(s) Settings.Wings = s end)
AddToggle(VisualsPage, "Jump Circle", function(s) Settings.JumpCircle = s end)

-- [Основной цикл]
RunService.RenderStepped:Connect(function()
    -- Rage Logic
    if Settings.AimbotEnabled then
        local closest, dist = nil, AimbotFOV
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") then
                local pos, onScreen = Camera:WorldToScreenPoint(v.Character.Head.Position)
                if onScreen then
                    local d = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                    if d < dist then closest = v; dist = d end
                end
            end
        end
        if closest then Camera.CFrame = CFrame.new(Camera.CFrame.Position, closest.Character.Head.Position) end
    end
    
    if Settings.TriggerBot and Mouse.Target and Mouse.Target.Parent:FindFirstChild("Humanoid") then
        mouse1press(); task.wait(0.05); mouse1release()
    end

    -- Visuals Logic
    if Settings.Wings and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("UpperTorso") then
        if not WingsPart then WingsPart = Instance.new("Part", LocalPlayer.Character.UpperTorso); WingsPart.Size = Vector3.new(2,2,0.5); Instance.new("SpecialMesh", WingsPart).MeshId = "rbxassetid://135898393" end
        WingsPart.Color = Color3.new(1,1,1); WingsPart.Material = Enum.Material.Neon
    elseif WingsPart then WingsPart:Destroy(); WingsPart = nil end

    -- Chams Logic
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character then
            local h = p.Character:FindFirstChild("Bypassed_Highlight") or Instance.new("Highlight", p.Character)
            h.Name = "Bypassed_Highlight"; h.Enabled = Settings.ChamsEnabled
            h.FillColor = p.Team and p.TeamColor.Color or Color3.fromRGB(255,0,0)
            h.OutlineColor = h.FillColor
        end
    end
end)

-- Прыжок
LocalPlayer.CharacterAdded:Connect(function(c)
    c:WaitForChild("Humanoid").StateChanged:Connect(function(_, new)
        if new == Enum.HumanoidStateType.Jumping and Settings.JumpCircle then CreateJumpCircle(c.HumanoidRootPart.Position) end
    end)
end)

UIS.InputBegan:Connect(function(i) if i.KeyCode == Enum.KeyCode.K then MainFrame.Visible = not MainFrame.Visible end end)
