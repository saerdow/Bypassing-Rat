                    local tp,tOn=Camera:WorldToViewportPoint(root.Position+Vector3.new(0,3,0))
                    local bp,bOn=Camera:WorldToViewportPoint(root.Position-Vector3.new(0,3.5,0))
                    if tOn and bOn then
                        local h=bp.Y-tp.Y; local w=h/2; local x1,y1=tp.X-w/2,tp.Y; local x2,y2=tp.X+w/2,bp.Y
                        esp.Lines.Top.From=Vector2.new(x1,y1); esp.Lines.Top.To=Vector2.new(x2,y1)
                        esp.Lines.Bottom.From=Vector2.new(x1,y2); esp.Lines.Bottom.To=Vector2.new(x2,y2)
                        esp.Lines.Left.From=Vector2.new(x1,y1); esp.Lines.Left.To=Vector2.new(x1,y2)
