local EspObjects = {}

local function ClearESP(playerName)
    if EspObjects[playerName] then
        for _, obj in pairs(EspObjects[playerName]) do if obj then obj:Destroy() end end
        EspObjects[playerName] = nil
    end
end

local function ApplyESP(player)
    if player == LocalPlayer then return end
    
    local function draw(char)
        if not char then return end
        ClearESP(player.Name)
        
        local root = char:WaitForChild("HumanoidRootPart", 5)
        local head = char:WaitForChild("Head", 5)
        if not root or not head then return end
        
        local list = {}
        local highlight = Instance.new("Highlight")
        highlight.FillColor = ESP_Color
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.4
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Adornee = char
        highlight.Enabled = ESP_Chams_Enabled and ESP_Enabled
        highlight.Parent = char
        table.insert(list, highlight)
        
        local billboard = Instance.new("BillboardGui")
        billboard.AlwaysOnTop = true
        billboard.Size = UDim2.new(0, 100, 0, 30)
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.Adornee = head
        billboard.Enabled = ESP_Enabled
        
        local txt = Instance.new("TextLabel")
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Text = player.Name
        txt.TextColor3 = ESP_Color
        txt.Font = Enum.Font.SourceSansBold
        txt.TextSize = ESP_TextSize
        txt.Parent = billboard
        
        billboard.Parent = char
        table.insert(list, billboard)
        EspObjects[player.Name] = list

        task.spawn(function()
            while char and char.Parent and EspObjects[player.Name] do
                highlight.Enabled = ESP_Chams_Enabled and ESP_Enabled
                highlight.FillColor = ESP_Color
                billboard.Enabled = ESP_Enabled
                txt.TextColor3 = ESP_Color
                txt.TextSize = ESP_TextSize
                task.wait(0.4)
            end
        end)
    end
    
    if player.Character then task.spawn(draw, player.Character) end
    player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        if ESP_Enabled then draw(char) end
    end)
end

local function RefreshESPState()
    for _, p in pairs(Players:GetPlayers()) do
        if not ESP_Enabled then ClearESP(p.Name) else ApplyESP(p) end
    end
end

local function CreateJumpCircle(position)
    if not JumpCircles_Enabled then return end
    
    local CirclePart = Instance.new("Part")
    CirclePart.Shape = Enum.PartType.Cylinder
    CirclePart.Material = Enum.Material.Neon
    CirclePart.Color = JumpCircles_Color
    CirclePart.Size = Vector3.new(0.2, 2, 2)
    CirclePart.CFrame = CFrame.new(position - Vector3.new(0, 2.8, 0)) * CFrame.Angles(0, 0, math.rad(90))
    CirclePart.Anchored = true
    CirclePart.CanCollide = false
    CirclePart.Transparency = 0.2
    CirclePart.Parent = workspace
    
    local TweenInf = TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local Goal = {
        Size = Vector3.new(0.2, 14, 14),
        Transparency = 1
    }
    
    local Tween = TweenService:Create(CirclePart, TweenInf, Goal)
    Tween:Play()
    Tween.Completed:Connect(function()
        CirclePart:Destroy()
    end)
end

-- ОБРАБОТКА ВВОДА И КЛАВИШ БИНДОВ
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    
    if input.KeyCode == SilentAimKey and not IsBindingSilentKey then
        SilentAimEnabled = not SilentAimEnabled
    end
    if input.KeyCode == AutoShotKey and not IsBindingAutoShotKey then
        AutoShotEnabled = not AutoShotEnabled
    end
    if input.KeyCode == FlyKey and not IsBindingFlyKey then
        FlyEnabled = not FlyEnabled
    end

    -- ТЕЛЕПОРТ
    if input.KeyCode == TeleportKey and TeleportMode ~= "None" and not IsBindingTPKey then
        local Character = LocalPlayer.Character
        if not Character then return end
        local Root = Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character:FindFirstChild("Humanoid")
        if not Root or not Humanoid then return end
        
        local targetPos = Mouse.Hit.Position + Vector3.new(0, 3, 0)
        
        if TeleportMode == "Default" then
            Root.CFrame = CFrame.new(targetPos)
        elseif TeleportMode == "CounterMine" then
            task.spawn(function()
                local startPos = Root.Position
                local direction = (targetPos - startPos).Unit
                local distance = (targetPos - startPos).Magnitude
                local stepSize = 35 
                local currentDist = 0
                
                while currentDist < distance do
                    if TeleportMode == "None" or not Root or not Character.Parent then break end
                    currentDist = math.clamp(currentDist + stepSize, 0, distance)
                    Humanoid:ChangeState(Enum.HumanoidStateType.Freefall)
                    Root.CFrame = CFrame.new(startPos + (direction * currentDist))
                    Root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    task.wait() 
                end
                if TeleportMode ~= "None" and Root then
                    Root.CFrame = CFrame.new(targetPos)
                end
            end)
        end
    end
    
    if input.KeyCode == Enum.KeyCode.K then
        MainFrame.Visible = not MainFrame.Visible
        WidgetFrame.Visible = MainFrame.Visible
    end
end)

