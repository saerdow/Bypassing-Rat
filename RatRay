local function ClearESP(name)
    pcall(function()
        if EspObjects[name] then for _,o in pairs(EspObjects[name]) do if o then o:Destroy() end end; EspObjects[name]=nil end
        if TracerLines[name] then TracerLines[name]:Remove(); TracerLines[name]=nil end
        if ESP_Cache[name] then
            for _,l in pairs(ESP_Cache[name].Lines) do l:Remove() end
            ESP_Cache[name].Health:Remove(); ESP_Cache[name]=nil
        end
    end)
end

local function Create2DESP(name)
    if ESP_Cache[name] then return end
    local lines={Top=Drawing.new("Line"),Bottom=Drawing.new("Line"),Left=Drawing.new("Line"),Right=Drawing.new("Line")}
    local hp=Drawing.new("Line")
    for _,l in pairs(lines) do l.Thickness=1.5; l.Color=ESP_BoxColor; l.Visible=false end
    hp.Thickness=2.5; hp.Visible=false
    ESP_Cache[name]={Lines=lines,Health=hp}
end

local function ApplyESP(player)
    if player==LocalPlayer then return end
    Create2DESP(player.Name)
    local function draw(char)
        if not char then return end
        ClearESP(player.Name); Create2DESP(player.Name)
        local root=char:WaitForChild("HumanoidRootPart",5)
        local head=char:WaitForChild("Head",5)
        if not root or not head then return end
        local list={}
        
        if VisibleChamsEnabled then
            local hlVisible = Instance.new("Highlight")
            hlVisible.FillColor = Color3.fromRGB(0, 255, 0)
            hlVisible.OutlineColor = Color3.fromRGB(0, 255, 0)
            hlVisible.FillTransparency = 0.7
            hlVisible.OutlineTransparency = 0
            hlVisible.DepthMode = Enum.HighlightDepthMode.Occluded
            hlVisible.Adornee = char
            hlVisible.Parent = char
            table.insert(list, hlVisible)
            
            local hlHidden = Instance.new("Highlight")
            hlHidden.FillColor = Color3.fromRGB(255, 0, 0)
            hlHidden.OutlineColor = Color3.fromRGB(255, 0, 0)
            hlHidden.FillTransparency = 0.8
            hlHidden.OutlineTransparency = 0
            hlHidden.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hlHidden.Adornee = char
            hlHidden.Parent = char
            table.insert(list, hlHidden)
        else
            local highlight = Instance.new("Highlight")
            highlight.FillColor = ESP_Color
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
            highlight.FillTransparency = 0.4
            highlight.OutlineTransparency = 0
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            highlight.Adornee = char
            highlight.Enabled = ESP_Chams_Enabled and ESP_Enabled
            highlight.Parent = char
            table.insert(list, highlight)
        end
        
        local billboard = Instance.new("BillboardGui")
        billboard.AlwaysOnTop = true
        billboard.Size = UDim2.new(0, 100, 0, 30)
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.Adornee = head
        billboard.Enabled = ESP_Enabled
        local txt = Instance.new("TextLabel")
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Text = player.Name
        txt.TextColor3 = ESP_Color
        txt.Font = Enum.Font.SourceSansBold
        txt.TextSize = ESP_TextSize
        txt.Parent = billboard
        billboard.Parent = char
        table.insert(list, billboard)
        EspObjects[player.Name] = list
    end
    if player.Character then task.spawn(draw, player.Character) end
    player.CharacterAdded:Connect(function(c) task.wait(0.5); ClearESP(player.Name); if ESP_Enabled then draw(c) end end)
end

local function RefreshESP()
